# Maintainer: Omindu Gunathilaka <your-email@example.com>

pkgname=pulse-tui-git
pkgver=r0.git
pkgrel=1
pkgdesc="Production-grade terminal system monitor with animated cyberpunk TUI (git)"
arch=('x86_64' 'aarch64')
url="https://github.com/OminduD/pulse"
license=('MIT')
depends=()
makedepends=('rust' 'cargo' 'git')
provides=('pulse-tui')
conflicts=('pulse-tui')
source=("$pkgname::git+https://github.com/OminduD/pulse.git")
sha256sums=('SKIP')

pkgver() {
    cd "$pkgname"
    printf "r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$pkgname"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "$pkgname"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --frozen
}

check() {
    cd "$pkgname"
    cargo test --release --frozen
}

package() {
    cd "$pkgname"
    install -Dm755 target/release/pulse    "$pkgdir/usr/bin/pulse"
    install -Dm644 LICENSE                 "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md               "$pkgdir/usr/share/doc/$pkgname/README.md"
}
